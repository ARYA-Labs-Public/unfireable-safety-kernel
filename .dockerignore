# Keep the build context small. The builder stage only needs source +
# Cargo.toml/Cargo.lock; everything else is noise.

target/
**/target/
**/*.rs.bk
*.profraw

# Editor / OS noise
.idea/
.vscode/
.DS_Store

# Git internals (Cargo doesn't need them at build time)
.git/
.gitignore
.github/

# Docs and figures — the runtime image doesn't ship them
docs/
README.md
CHANGELOG.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
LICENSE

# Tests + benches don't go in the kernel image. examples/ is partially
# kept — examples/reference_app_rs is a workspace member referenced by
# the root Cargo.toml, so excluding it breaks `cargo build --locked`.
# The non-Rust examples (Python reference app, observability dashboards,
# policy DSL) are pulled out so the build context doesn't bloat.
tests/
benches/
examples/reference_app/
examples/middleware/
examples/observability/
examples/policy/
examples/testing/

# Python defense library is shipped separately
py-defense/

# Local secrets — never include in any image
.env
.env.*
*.pub
*.key
operator.*
